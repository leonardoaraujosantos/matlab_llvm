module {
  func.func @script() {
    %cst = arith.constant 6.000000e+00 : f64
    %cst_0 = arith.constant 5.000000e+00 : f64
    %cst_1 = arith.constant 4.000000e+00 : f64
    %cst_2 = arith.constant 1.000000e+00 : f64
    %cst_3 = arith.constant 2.000000e+00 : f64
    %cst_4 = arith.constant 3.000000e+00 : f64
    %0 = "matlab.concat_row"(%cst_2, %cst_3, %cst_4) {matlab.name = "a"} : (f64, f64, f64) -> tensor<3xf64>
    %1 = "matlab.concat_row"(%cst_1, %cst_0, %cst) {matlab.name = "b"} : (f64, f64, f64) -> tensor<3xf64>
    %2 = "matlab.emul"(%0, %1) {matlab.name = "c"} : (tensor<3xf64>, tensor<3xf64>) -> tensor<3xf64>
