matlab.module() {
  matlab.func @script() {name = @script, num_inputs = 0, num_outputs = 0} {
    %0 = matlab.make_handle() {callee = @sin} : @handle
    %1 = matlab.alloc() {name = @f} : @handle
    matlab.store(%0, %1)
    %2 = matlab.make_anon() {params = "x"} : @handle {
      %3 = matlab.load(%4) : any
      %5 = matlab.const_int() {value = 2} : double
      %6 = matlab.epow(%3, %5) : any
      %7 = matlab.const_int() {value = 1} : double
      %8 = matlab.add(%6, %7) : any
      scf.yield(%8)
    }
    %4 = matlab.alloc() {name = @x} : any
    %9 = matlab.alloc() {name = @g} : @handle
    matlab.store(%2, %9)
    matlab.return()
  }
}
