matlab.module() {
  matlab.func @demo(%0: any) {name = @demo, num_inputs = 1, num_outputs = 1} {
    %1 = matlab.alloc() {name = @x} : any
    matlab.store(%0, %1)
    %2 = matlab.alloc() {name = @n} : double
    %3 = matlab.const_int() {value = 0} : double
    matlab.store(%3, %2)
    scf.while() {
      %4 = matlab.load(%1) : any
      %5 = matlab.const_int() {value = 1} : double
      %6 = matlab.gt(%4, %5) : logical
      scf.yield(%6)
    } {
      %7 = matlab.load(%1) : any
      %8 = matlab.const_int() {value = 2} : double
      %9 = matlab.matdiv(%7, %8) : any
      matlab.store(%9, %1)
      %10 = matlab.load(%2) : double
      %11 = matlab.const_int() {value = 1} : double
      %12 = matlab.add(%10, %11) : double
      matlab.store(%12, %2)
      scf.yield()
    }
    %13 = matlab.load(%2) : double
    matlab.return(%13)
  }
}
